    "dompurify": "~3.4.3",
    "lucide-react": "~1.16.0",
    "marked": "~18.0.3",
    "mermaid": "~11.15.0",
    "react": "~19.2.6",
    "react-dom": "~19.2.6",
    "react-hook-form": "~7.76.0",
    "react-router-dom": "~7.15.1",
    "zod": "~4.4.3",
    "zustand": "~5.0.13"
